generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Villa {
  id              String           @id @default(cuid())
  name            String
  location        String
  description     String
  legalStructure  String           @default("FRACTIONAL_OWNERSHIP")
  totalShares     Int              @default(100)
  pricePerShare   Float
  totalValue      Float
  images          String[]
  nftAddress      String?          @unique
  availableShares Int              @default(100)
  chain           String?          @default("ethereum")
  occupancyStatus String           @default("VACANT")
  nightlyRate     Float            @default(0)
  ery             Float            @default(0)
  ary             Float            @default(0)
  totalTokens     Int              @default(0)
  tokensSold      Int              @default(0)
  bedrooms        Int              @default(0)
  bathrooms       Int              @default(0)
  sqm             Float            @default(0)
  lastMaintenance DateTime         @default(now())
  nextMaintenance DateTime?
  listingId       Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  maintenanceLogs MaintenanceLog[]
  marketPrices    MarketPrice[]
  revenues        Revenue[]
  shares          Share[]
}

model MaintenanceLog {
  id        String   @id @default(cuid())
  villaId   String
  activity  String
  cost      Float
  date      DateTime @default(now())
  performer String
  status    String   @default("COMPLETED")
  villa     Villa    @relation(fields: [villaId], references: [id])
}

model MarketPrice {
  id         String   @id @default(cuid())
  villaId    String
  price      Float
  recordedAt DateTime @default(now())
  source     String
  villa      Villa    @relation(fields: [villaId], references: [id])
}

model Share {
  id           String   @id @default(cuid())
  villaId      String
  ownerAddress String
  amount       Int      @default(1)
  boughtAt     DateTime @default(now())
  villa        Villa    @relation(fields: [villaId], references: [id])

  @@unique([villaId, ownerAddress])
}

model Revenue {
  id            String    @id @default(cuid())
  villaId       String
  amount        Float
  period        DateTime
  distributedAt DateTime?
  payouts       Payout[]
  villa         Villa     @relation(fields: [villaId], references: [id])
}

model Payout {
  id           String   @id @default(cuid())
  revenueId    String
  ownerAddress String
  amount       Float
  status       String   @default("PENDING")
  txHash       String?
  createdAt    DateTime @default(now())
  revenue      Revenue  @relation(fields: [revenueId], references: [id])
}

model User {
  id           String     @id @default(cuid())
  address      String     @unique
  name         String?
  role         Role       @default(INVESTOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  referralCode String?    @unique
  referrals    Referral[] @relation("Referrer")
}

model Referral {
  id              String   @id @default(cuid())
  referrerAddress String
  investorAddress String
  villaId         String
  amountSol       Float
  commissionSol   Float
  status          String   @default("COMPLETED")
  txHash          String?  @unique
  createdAt       DateTime @default(now())
  referrer        User     @relation("Referrer", fields: [referrerAddress], references: [address])
}

enum Role {
  ADMIN
  MANAGER
  INVESTOR
}
